# Postgres connection (matches docker-compose)
DATABASE_URL="postgresql://swim:swim@localhost:5432/swim?schema=public"

# Auth — JWT_SECRET MUST be a strong random string (>=16 chars).
# The API fails to start if this is missing, too short, or the placeholder below.
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-in-prod"
JWT_EXPIRES_IN="1d"

PORT=3000

# CORS allowlist for the web client (comma-separated). Defaults to the Vite dev origin.
CORS_ORIGIN="http://localhost:5173"

# Timezone used to bucket the dashboard heatmap/trend by calendar day.
# Defaults to UTC; set e.g. Asia/Shanghai to match the operator's local day.
APP_TIMEZONE="UTC"
