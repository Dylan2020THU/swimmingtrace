# Postgres connection (matches docker-compose)
DATABASE_URL="postgresql://swim:swim@localhost:5432/swim?schema=public"

# Auth — JWT_SECRET MUST be a strong random string (>=16 chars).
# The value below is a DEV-only placeholder so `cp .env.example .env` boots locally.
# For production generate a real secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# (The API refuses to start if JWT_SECRET is missing, too short, or "change-me-in-prod".)
JWT_SECRET="dev-only-secret-change-in-prod-0123456789"
JWT_EXPIRES_IN="1d"

PORT=3000

# CORS allowlist for the web clients (comma-separated): owner console + swimmer app.
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# Base URL of the swimmer mobile app — used to build account-claim links.
SWIMMER_APP_URL="http://localhost:5174"

# Timezone used to bucket the dashboard heatmap/trend by calendar day.
# Defaults to UTC; set e.g. Asia/Shanghai to match the operator's local day.
APP_TIMEZONE="UTC"
