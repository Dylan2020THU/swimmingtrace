// Prisma schema — swim-marathon MVP
// Geo "nearby" search uses raw SQL (PostGIS); see places.service.ts.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

enum Role {
  ADMIN
  OWNER
  SWIMMER
}

enum RegistrationStatus {
  ACTIVE
  INACTIVE
}

enum Plan {
  FREE
  PRO
}

enum Gender {
  MALE
  FEMALE
}

enum Stroke {
  FREE
  BACK
  BREAST
  FLY
  IM
}

enum ResultStatus {
  ENTERED
  OK
  DNS
  DNF
  DQ
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  name          String?
  role          Role           @default(SWIMMER)
  plan          Plan           @default(FREE)
  planUpdatedAt DateTime?
  gender        Gender?
  birthDate     DateTime?
  ownedPools    Pool[]         @relation("PoolOwner")
  registrations Registration[]
  sessions      SwimSession[]
  refreshTokens RefreshToken[]
  idempotencyKeys IdempotencyKey[]
  apiKeys       ApiKey[]
  meets         Meet[]         @relation("MeetOwner")
  seasons       Season[]       @relation("SeasonOwner")
  meetEntries   MeetEntry[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  claimedAt     DateTime?
  claimToken          String?   @unique
  claimTokenExpiresAt DateTime?
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  emailVerifiedAt      DateTime?
  emailVerifyTokenHash String?
  emailVerifyExpiresAt DateTime?
}

model Pool {
  id            String         @id @default(uuid())
  name          String
  address       String?
  // Stored as plain columns; PostGIS distance is computed from these in raw SQL.
  latitude      Float?
  longitude     Float?
  ownerId       String
  owner         User           @relation("PoolOwner", fields: [ownerId], references: [id])
  registrations Registration[]
  sessions      SwimSession[]
  challenges    Challenge[]
  hostedMeets   Meet[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  archivedAt    DateTime?
}

// A time-boxed collective distance goal for a pool, with a per-swimmer leaderboard
// computed from SwimSession within [startDate, endDate).
model Challenge {
  id                 String   @id @default(uuid())
  poolId             String
  pool               Pool     @relation(fields: [poolId], references: [id])
  name               String
  goalDistanceMeters Int
  startDate          DateTime
  endDate            DateTime
  createdAt          DateTime @default(now())

  @@index([poolId])
}

// Links a swimmer to a pool (the "registered in his place" relationship).
model Registration {
  id        String             @id @default(uuid())
  swimmerId String
  poolId    String
  status    RegistrationStatus @default(ACTIVE)
  swimmer   User               @relation(fields: [swimmerId], references: [id])
  pool      Pool               @relation(fields: [poolId], references: [id])
  joinedAt  DateTime           @default(now())

  @@unique([swimmerId, poolId])
}

model SwimSession {
  id              String   @id @default(uuid())
  swimmerId       String
  poolId          String?
  distanceMeters  Int
  durationSeconds Int?
  swamAt          DateTime
  swimmer         User     @relation(fields: [swimmerId], references: [id])
  pool            Pool?    @relation(fields: [poolId], references: [id])
  createdAt       DateTime @default(now())

  // Hot path for the heatmap: per-swimmer, ordered by date.
  @@index([swimmerId, swamAt])
}

// Rotating refresh tokens (hashed). A login starts a family; each /auth/refresh
// rotates within the family. Replaying a revoked token revokes the whole family.
model RefreshToken {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique
  familyId     String
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?
  replacedById String?

  @@index([userId])
  @@index([familyId])
}

// Stores the response of an authenticated create-POST keyed by (userId, Idempotency-Key)
// so a retry replays the original result instead of duplicating the side effect.
// `completedAt == null` marks an in-flight request (concurrent replays get 409).
model IdempotencyKey {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  key            String
  method         String
  path           String
  requestHash    String
  responseStatus Int?
  responseBody   Json?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@unique([userId, key])
  @@index([createdAt])
}

// Competition meet: a dated event hosted by an owner, containing race events.
model Meet {
  id         String      @id @default(uuid())
  ownerId    String
  owner      User        @relation("MeetOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name       String
  meetDate   DateTime
  hostPoolId String?
  hostPool   Pool?       @relation(fields: [hostPoolId], references: [id], onDelete: SetNull)
  laneCount  Int         @default(6)
  published  Boolean     @default(false)
  registrationOpen Boolean @default(false)
  seasonId   String?
  season     Season?     @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  events     RaceEvent[]
  createdAt  DateTime    @default(now())

  @@index([ownerId])
  @@index([seasonId])
}

// A season / meet series: meets grouped for a cross-meet points leaderboard.
// referenceDate fixes each swimmer's age group for the whole season (no mid-season drift).
model Season {
  id            String   @id @default(uuid())
  ownerId       String
  owner         User     @relation("SeasonOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name          String
  referenceDate DateTime
  published     Boolean  @default(false)
  meets         Meet[]
  createdAt     DateTime @default(now())

  @@index([ownerId])
}

// One race within a meet (e.g. 50m FREE). All categories swim it; results split by gender × age group.
model RaceEvent {
  id             String      @id @default(uuid())
  meetId         String
  meet           Meet        @relation(fields: [meetId], references: [id], onDelete: Cascade)
  distanceMeters Int
  stroke         Stroke
  order          Int         @default(0)
  entries        MeetEntry[]
  createdAt      DateTime    @default(now())

  @@index([meetId])
}

// A swimmer entered into a race event; the result (time + status) is inlined here.
model MeetEntry {
  id           String       @id @default(uuid())
  raceEventId  String
  raceEvent    RaceEvent    @relation(fields: [raceEventId], references: [id], onDelete: Cascade)
  swimmerId    String
  swimmer      User         @relation(fields: [swimmerId], references: [id], onDelete: Cascade)
  seedTimeMs   Int?
  resultTimeMs Int?
  resultStatus ResultStatus @default(ENTERED)
  heat         Int?
  lane         Int?
  createdAt    DateTime     @default(now())

  @@unique([raceEventId, swimmerId])
  @@index([raceEventId])
}

// Long-lived programmatic credential for an owner. Stored hashed (sha256); the
// plaintext (prefix swk_) is shown once at creation. A key acts as its owner.
model ApiKey {
  id         String    @id @default(uuid())
  ownerId    String
  owner      User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  label      String
  prefix     String
  keyHash    String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([ownerId])
}
